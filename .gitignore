*.acn
*.acr
*.alg
*.bbl
*.bcf
*.blg
*.brf
*.dvi
*.fdb_latexmk
*.fls
*.glg
*.glo
*.gls
*.idx
*.ilg
*.ind
*.ist
*.loa
*.lof
*.lol
*.lot
*.log
*.maf
*.mtc
*.mtc0
*.nav
*.nlo
*.nls
*.out
*.pdfsync
*.run.xml
*.snm
*.spl
*.synctex
*.synctex.gz
*.toc
*.upa
*.upb
*.vrb
*.xdv
*.xmpi
texput.log
_minted-*/
_markdown_*/

# Python/editor noise
__pycache__/
*.py[cod]
.DS_Store
.idea/
.vscode/

# Local source-document copies may contain third-party contact details.
source/*.docx
source/*.pdf
