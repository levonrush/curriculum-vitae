# Generated document output
build/

# Locally cached third-party marks. Their sources and hashes are tracked,
# but the marks themselves are not redistributed from this repository.
.vendor/

# TeX intermediates outside build/ (defensive). Normal builds put these under
# build/, but editors and one-off LaTeX commands sometimes leave them beside
# the source file.
